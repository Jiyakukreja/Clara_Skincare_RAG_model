# Server-side proxy target for POST /api/chat (used by Next.js route handler).
# Local default: http://127.0.0.1:8000/chat
# BACKEND_URL=http://127.0.0.1:8000/chat

# Vercel / production: point to your deployed FastAPI /chat endpoint.
# BACKEND_URL=https://your-fastapi-host.example.com/chat

# Optional: call the backend directly from the browser (skips /api/chat proxy).
# NEXT_PUBLIC_BACKEND_URL=https://your-fastapi-host.example.com/chat
