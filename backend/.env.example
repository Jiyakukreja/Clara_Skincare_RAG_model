FRONTEND_URL=http://localhost:3000

# AI provider for recommendation analysis.
# Use gemini for this project.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional OpenAI key is still used by the local FAISS embedding builder.
# If this is empty, the app falls back to keyword retrieval.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Database connection string.
# Example PostgreSQL local URL:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_skincare
DATABASE_URL=your_database_url_here

# Vector database configuration.
# Current MVP uses local FAISS. Recommended hosted option: Pinecone.
VECTOR_DB_PROVIDER=faiss
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=clinikally-products
PINECONE_NAMESPACE=products
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Gemini embedding setup for Pinecone.
# Create Pinecone index with the same dimension.
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSION=768
